<script>
    // 星级评分渲染（四舍五入，满分5星）
    function renderStars(el) {
        const score = parseFloat(el.dataset.score) || 0;
        const rounded = Math.round(score); // 四舍五入
        let html = '';
        for (let i = 1; i <= 5; i++) {
            html += i <= rounded
                ? '<span class="star"></span>'
                : '<span class="star empty"></span>';
        }
        el.innerHTML = html;
    }
    document.querySelectorAll('.stars[data-score]').forEach(renderStars);

</script>

