<script>
    // 搜索框轮播：只切换软件名，图标和输入框静态不变
    const keywords = ['抖音', 'WPS Office', '微信电脑版', 'QQ', '迅雷'];
    let kwIndex = 0;
    const kwText = document.getElementById('kwText');

    setInterval(() => {
        kwIndex = (kwIndex + 1) % keywords.length;
        kwText.style.opacity = '0';
        setTimeout(() => {
            kwText.textContent = keywords[kwIndex];
            kwText.style.opacity = '1';
        }, 400);
    }, 5000);

    // 输入时隐藏占位
    const searchForm = document.getElementById('searchForm');
    const input = document.getElementById('searchInput');
    const placeholder = document.querySelector('.search-placeholder');
    const updatePlaceholderVisibility = () => {
        const hasValue = input.value.trim() !== '';
        const isFocused = document.activeElement === input;
        placeholder.style.display = hasValue || isFocused ? 'none' : 'flex';
    };

    input.addEventListener('focus', updatePlaceholderVisibility);
    input.addEventListener('input', updatePlaceholderVisibility);
    input.addEventListener('blur', updatePlaceholderVisibility);
    window.addEventListener('pageshow', updatePlaceholderVisibility);
    updatePlaceholderVisibility();
    searchForm.addEventListener('submit', () => {
        input.value = input.value.trim() || kwText.textContent.trim();
        updatePlaceholderVisibility();
    });
</script>
