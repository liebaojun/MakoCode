<script>
    // 悬浮按钮组
    (function () {
        const root = document.getElementById('floatRoot');
        const bar = root.querySelector('.float-bar');
        const items = root.querySelectorAll('.float-item[data-popup]');
        const overlay = document.getElementById('floatOverlay');
        const backTop = document.getElementById('backTop');

        function closeAll() {
            root.querySelectorAll('.float-popup.show').forEach(p => p.classList.remove('show'));
            items.forEach(i => i.classList.remove('active'));
            overlay.classList.remove('show');
        }

        items.forEach(function (item) {
            item.addEventListener('click', function (e) {
                e.stopPropagation();
                var popupId = this.dataset.popup;
                var popup = document.getElementById(popupId);
                var isOpen = popup.classList.contains('show');

                closeAll();
                if (!isOpen) {
                    // 计算弹窗 top，使其箭头对准按钮中心
                    var barRect = bar.getBoundingClientRect();
                    var btnRect = this.getBoundingClientRect();
                    var rootRect = root.getBoundingClientRect();
                    // 按钮中心相对 floatRoot 顶部的位置
                    var btnCenterY = btnRect.top - rootRect.top + btnRect.height / 2;
                    // 弹窗先 show 以取高度
                    popup.style.top = '0px';
                    popup.classList.add('show');
                    var popH = popup.offsetHeight;
                    // 弹窗 top 使其箭头（在弹窗内的相对位置）对准按钮
                    // 默认让箭头在弹窗中心(popH/2)，使 top + popH/2 = btnCenterY
                    var popTop = btnCenterY - popH / 2;
                    // 限制不超出视口
                    var viewH = root.offsetHeight;
                    popTop = Math.max(8, Math.min(popTop, viewH - popH - 8));
                    popup.style.top = popTop + 'px';
                    // 箭头在弹窗内的位置 = btnCenterY - popTop
                    var arrowTop = btnCenterY - popTop;
                    arrowTop = Math.max(16, Math.min(arrowTop, popH - 16));
                    popup.style.setProperty('--arrow-top', arrowTop + 'px');
                    this.classList.add('active');
                    overlay.classList.add('show');
                }
            });
        });

        overlay.addEventListener('click', closeAll);

        backTop.addEventListener('click', function () {
            closeAll();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    })();
</script>

